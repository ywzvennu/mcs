# .env.example — copy to .env and fill in all values before running the
# production compose stack.
#
#   cp .env.example .env
#   $EDITOR .env
#   docker compose -f docker-compose.prod.yml up -d
#
# SECURITY: Never commit .env to version control.
# The .gitignore already excludes it.

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------

# Password for the 'mcs' Postgres user.  Generate with:
#   openssl rand -hex 32
POSTGRES_PASSWORD=change-me-strong-postgres-password

# ---------------------------------------------------------------------------
# MCS server — required secrets
# ---------------------------------------------------------------------------

# HMAC-SHA256 session signing key (>= 32 bytes, high entropy).
# ALL nodes must share the same secret so JWTs are valid on any node.
# Generate with:
#   openssl rand -hex 32
MCS_SESSION__SECRET=change-me-to-a-long-random-secret-min-32-bytes

# ---------------------------------------------------------------------------
# MCS server — domain / SIWE
# ---------------------------------------------------------------------------

# The public domain name that Caddy will serve and that SIWE challenges embed.
# Example: mcs.example.com
MCS_DOMAIN=mcs.example.com

# RFC 3986 authority for SIWE challenges (must match the domain clients connect to).
MCS_SIWE__DOMAIN=mcs.example.com

# RFC 3986 URI for SIWE challenges.
MCS_SIWE__URI=https://mcs.example.com

# ---------------------------------------------------------------------------
# MCS server — CORS (set to your frontend's origin)
# ---------------------------------------------------------------------------

# Comma-separated list of allowed browser origins.  Example:
#   MCS_CORS__ALLOWED_ORIGINS=https://app.example.com
# Leave empty if no browser client is used.
MCS_CORS__ALLOWED_ORIGINS=

# ---------------------------------------------------------------------------
# MCS server — payments (optional; disabled by default)
# ---------------------------------------------------------------------------

# Uncomment and configure to enable x402 game-creation payments.
# MCS_PAYMENTS__ENABLED=true
# MCS_PAYMENTS__VERIFIER=facilitator
# MCS_PAYMENTS__FACILITATOR_URL=https://facilitator.example.com
# MCS_PAYMENTS__FACILITATOR_API_KEY=your-api-key
# MCS_PAYMENTS__NETWORK=base
# MCS_PAYMENTS__PAY_TO=0xYourWalletAddress
# MCS_PAYMENTS__MAX_AMOUNT_REQUIRED=10000
